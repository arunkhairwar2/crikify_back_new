{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "ESNext.AsyncIterable"],
    "types": ["node", "jest", "express", "cors", "jsonwebtoken"],
    "typeRoots": ["node_modules/@types"],
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "pretty": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "allowJs": true,
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "paths": {
      "@config": ["./src/config/index.ts"],
      "@/config": ["./src/config/index.ts"],
      "@/app": ["./src/app.ts"],
      "@/generated/*": ["./src/generated/*.ts"],
      "@controllers/*": ["./src/controllers/*.ts"],
      "@databases/*": ["./src/databases/*.ts"],
      "@dtos/*": ["./src/dtos/*.ts"],
      "@exceptions/*": ["./src/exceptions/*.ts"],
      "@interfaces/*": ["./src/interfaces/*.ts"],
      "@middlewares/*": ["./src/middlewares/*.ts"],
      "@models/*": ["./src/models/*.ts"],
      "@routes/*": ["./src/routes/*.ts"],
      "@services/*": ["./src/services/*.ts"],
      "@utils/*": ["./src/utils/*.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.json", ".env", "prisma.config.ts"],
  "exclude": ["node_modules", "src/http", "src/logs", "src/tests"],
  "ts-node": {
    "experimentalResolver": true
  }
}
